# ── Appwrite (Client) ────────────────────────────────────────────────
# Die Defaults im Code entsprechen bereits diesen Werten. Nur setzen,
# wenn du von den IDs abweichst, die scripts/setup-appwrite.mjs anlegt.
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=6a3bbc6600236e6bf22a
NEXT_PUBLIC_APPWRITE_DATABASE_ID=roteagenda
NEXT_PUBLIC_APPWRITE_PROJECTS_COLLECTION_ID=projects
NEXT_PUBLIC_APPWRITE_TASKS_COLLECTION_ID=tasks
NEXT_PUBLIC_APPWRITE_RAW_NOTES_COLLECTION_ID=rawNotes
NEXT_PUBLIC_APPWRITE_SUGGESTIONS_COLLECTION_ID=suggestions

# ── Appwrite (nur für scripts/setup-appwrite.mjs, nicht für die App) ─
# API-Key mit databases.read + databases.write, angelegt in der
# Appwrite Console unter Overview → Integrations → API keys.
# APPWRITE_API_KEY=

# ── Google-Integration (optional) ────────────────────────────────────
# OAuth-Client-ID (Typ "Webanwendung") aus der Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 und
# https://roteagenda.appwrite.network
# Zusätzlich unter "APIs & Services" aktivieren: Google Tasks API und
# Google Calendar API. Ohne Client-ID funktioniert nur der
# Kalender-Button (öffnet Google Kalender mit vorbefülltem Termin).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ── KI über OpenRouter (empfohlen: ein Key für alle Modelle) ─────────
# Key erstellen auf https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Sprachnotiz-Transkription (nutzt denselben OpenRouter-Key).
# Modell muss Audio-Eingabe unterstützen:
# OPENROUTER_TRANSCRIBE_MODEL=google/gemini-2.5-flash
#
# Foto-Notizen / OCR (nutzt denselben OpenRouter-Key).
# Modell muss Bild-Eingabe unterstützen:
# OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
#
# Optionale Slug-Overrides, falls ein Modell im OpenRouter-Katalog
# anders heißt (https://openrouter.ai/models):
# OPENROUTER_GPT_5_5_MODEL=openai/gpt-5.5
# OPENROUTER_GLM_5_2_MODEL=z-ai/glm-5.2
# OPENROUTER_KIMI_K2_7_MODEL=moonshotai/kimi-k2.7
# OPENROUTER_QWEN_3_7_PLUS_MODEL=qwen/qwen3.7-plus
# OPENROUTER_QWEN_3_7_MAX_MODEL=qwen/qwen3.7-max
# OPENROUTER_MINIMAX_M3_MODEL=minimax/minimax-m3
# OPENROUTER_DEEPSEEK_V4_PRO_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_DEEPSEEK_V4_FLASH_MODEL=deepseek/deepseek-v4-flash

# ── Alternativ: direkte Provider-Keys (haben Vorrang vor OpenRouter) ─
# Nur serverseitig, niemals NEXT_PUBLIC!
# OPENAI_API_KEY=
# ZAI_API_KEY=
# MOONSHOT_API_KEY=
# DASHSCOPE_API_KEY=
# MINIMAX_API_KEY=
# DEEPSEEK_API_KEY=

# ── Optionale Overrides für Modell-Slugs und Base-URLs ───────────────
# Nur nötig, wenn der Anbieter andere Namen erwartet als die Defaults.
# OPENAI_GPT_5_5_MODEL=gpt-5.5
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_GLM_5_2_MODEL=glm-5.2
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# MOONSHOT_KIMI_K2_7_MODEL=kimi-k2.7
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_QWEN_3_7_PLUS_MODEL=qwen3.7-plus
# DASHSCOPE_QWEN_3_7_MAX_MODEL=qwen3.7-max
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_M3_MODEL=MiniMax-M3
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro
# DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash
